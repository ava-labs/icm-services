    }

    function unpackValidatorSetMerkleAttestation(bytes calldata data)
        internal
        pure
        returns (uint256, ValidatorSetMerkleAttestation memory)
    {
        /* solhint-disable */
        uint256 _initial_length = data.length;
        ValidatorSetMerkleAttestation memory result;

        Validator[] memory signers;
        {
            uint256 length = uint256(uint32(bytes4(data[0:4])));
            data = data[4:];
            signers = new Validator[](length);
            for (uint256 i = 0; i < length;) {
                Validator memory signers_1;
                {
                    uint256 read;
                    (read, signers_1) = unpackValidator(data);
                    data = data[read:];
