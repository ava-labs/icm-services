        bytes32 avalancheBlockchainID = bytes32(data[0:32]);
        data = data[32:];
        result.avalancheBlockchainID = avalancheBlockchainID;
        uint64 pChainHeight = uint64(bytes8(data[0:8]));
        data = data[8:];
        result.pChainHeight = pChainHeight;
        uint64 pChainTimestamp = uint64(bytes8(data[0:8]));
        data = data[8:];
        result.pChainTimestamp = pChainTimestamp;
        bytes32[] memory shardHashes;
        {
            uint256 length = uint256(uint32(bytes4(data[0:4])));
            data = data[4:];
            shardHashes = new bytes32[](length);
            for (uint256 i = 0; i < length;) {
                bytes32 shardHashes_1 = bytes32(data[0:32]);
                data = data[32:];
                shardHashes[i] = shardHashes_1;
                unchecked {
                    ++i;
                }
            }
        }
        result.shardHashes = shardHashes;

        return (_initial_length - data.length, result);
        /* solhint-enable */
    }

    function parseValidatorSetShard(bytes calldata data) internal pure returns (uint256, ValidatorSetShard memory) {
        /* solhint-disable */
